function Show-Tree {
    param(
        [string]$Path = ".",
        [string[]]$Exclude = @("node_modules", ".next")
    )

    Get-ChildItem -LiteralPath $Path | Where-Object {
        $Exclude -notcontains $_.Name
    } | ForEach-Object {
        Write-Host $_.Name
        if ($_.PSIsContainer) {
            tree $_.FullName /F
        }
    }
}

